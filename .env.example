PORT=3000
NODE_ENV=development

# Facebook Messenger Platform
PAGE_ACCESS_TOKEN=replace_with_page_access_token
VERIFY_TOKEN=replace_with_custom_webhook_verify_token
META_APP_SECRET=replace_with_meta_app_secret
REQUIRE_META_SIGNATURE=false
PAGE_ID=

# OpenAI AI fallback
AI_ENABLED=true
OPENAI_API_KEY=replace_with_openai_api_key
OPENAI_MODEL=gpt-5.4-nano
OPENAI_MAX_OUTPUT_TOKENS=160

# Public business details
BUSINESS_ADDRESS=[BUSINESS_ADDRESS]
GOOGLE_MAPS_LINK=[GOOGLE_MAPS_LINK]
CONTACT_NUMBER=[CONTACT_NUMBER]
LANDMARK_INSTRUCTIONS=Near [LANDMARK_OR_DIRECTION_DETAILS]

# Local inquiry storage
INQUIRIES_FILE=./data/inquiries.json

# Production hardening
JSON_BODY_LIMIT=256kb
GENERAL_RATE_LIMIT_WINDOW_MS=900000
GENERAL_RATE_LIMIT_MAX=600
WEBHOOK_RATE_LIMIT_WINDOW_MS=60000
WEBHOOK_RATE_LIMIT_MAX=300
